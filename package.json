{
  "name": "kanban-md",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run server\" \"vite\"",
    "server": "tsx watch server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src server shared mcp",
