# Local LLM runtime (OpenAI-compatible). Copy to `.env` and adjust for your setup.
# Base URLs default to LM Studio (:1234). llama.cpp llama-server uses :8080;
# Ollama uses :11434. Chat and embeddings are kept separate so a llama.cpp user
# can point them at two server instances; LM Studio serves both from one port.
# Keep these as the HOST sees them — an embedded-terminal container is handed the same values with
# loopback rewritten to host.docker.internal, so don't hardcode that here (tkt-c0cf617fdcc4).
LLM_BASE_URL=http://localhost:1234/v1
EMBED_BASE_URL=http://localhost:1234/v1

# Model ids as the runtime advertises them (curl <base>/v1/models).
# LLM_MODEL — open-weight quality ladder, all run locally with no key:
#   qwen3-coder-30b-a3b  best tool-calling + summaries
#   openai/gpt-oss-20b   great on ~16 GB
#   qwen3.5-9b           lightest (summaries can be thin)
LLM_MODEL=openai/gpt-oss-20b
EMBED_MODEL=text-embedding-qwen3-embedding-0.6b

# Sampling params (optional). Intake is a CLASSIFICATION task (pick a type /
# priority / project), so the chat model defaults to temperature 0 for a
# deterministic, reproducible classification — the same report lands the same
# way every run. Raise it only if you want more varied phrasing.
#   LLM_TEMPERATURE   default 0; a blank/garbage value falls back to 0
#   LLM_TOP_P         nucleus sampling; unset ⇒ omitted (runtime default stands)
#   LLM_SEED          integer RNG seed, when the runtime honors it; unset ⇒ omitted
#   LLM_REASONING_EFFORT  low|medium|high (gpt-oss et al) — an ACCURACY dial, not
#                     a speed one (high measured ~6x slower); unset ⇒ omitted
# LLM_TEMPERATURE=0
# LLM_TOP_P=
# LLM_SEED=
# LLM_REASONING_EFFORT=

# Embedding task-instruction prefixes. Optional — auto-applied for known
# embedders (Qwen3-Embedding, nomic). Set these to point at ANY other embedder
# that needs prefixes (e.g. E5: "query: " / "passage: "); leave unset otherwise.
# EMBED_QUERY_PREFIX=
# EMBED_DOC_PREFIX=

# Persistent embedding cache (opt-in). When set, embeddings are keyed by content
# hash + model and stored on disk, so board changes re-embed only what changed
# and a restart re-embeds nothing. Leave UNSET for the zero-config default (pure
# in-memory; re-embeds on boot). Prefer an ABSOLUTE path so every process shares
# one cache — a relative path resolves against each process's cwd (server vs CLI
# would diverge). The default dir (.cache/) is gitignored — local-only.
# EMBED_CACHE_PATH=/absolute/path/to/.cache/embeddings.json

# Bring your own key (optional): to use a CLOUD chat model, point LLM_BASE_URL
# at an OpenAI-compatible endpoint and set LLM_API_KEY (a bearer token — .env
# only, never commit). OpenAI: https://api.openai.com/v1. Claude:
# https://api.anthropic.com/v1 (best-effort compat shim — verify tool-calling).
# NOTE: retrieval still needs an embedder; Anthropic has none, so keep a local
# embedder (the embedder is keyless/local-only today).
# LLM_API_KEY=

# Used by the CI code-review workflow (as a GitHub Actions secret) — NOT read by
# the agent (it uses LLM_API_KEY above for cloud). Optional for local dev.
# ANTHROPIC_API_KEY=
